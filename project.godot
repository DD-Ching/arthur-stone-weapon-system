; Engine configuration file.
; Arthur Stone Weapon System — 2D heavy-weapon prototype.
;
; This file is generated/maintained by Godot, but is hand-authored here for the
; initial commit so the repository is openable straight from a clean checkout.
; Open the project by pointing Godot 4.3+ at this folder.

config_version=5

[application]

config/name="Arthur Stone Weapon System"
config/description="A 2D prototype about the chosen one who failed the test and lifted the whole stone instead of the sword. Power vs control, weight vs mobility."
run/main_scene="res://scenes/Battlefield.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"
boot_splash/show_image=false

[autoload]

Impact="*res://scripts/Impact.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

