# Normalise line endings so the project diffs cleanly across Windows / macOS / Linux.
* text=auto eol=lf

*.gd     text eol=lf
*.tscn   text eol=lf
*.tres   text eol=lf
*.godot  text eol=lf
*.cfg    text eol=lf
*.md     text eol=lf
*.svg    text eol=lf
*.yml    text eol=lf

# Binary assets — never touch these.
*.png  binary
*.jpg  binary
*.webp binary
*.ogg  binary
*.wav  binary
